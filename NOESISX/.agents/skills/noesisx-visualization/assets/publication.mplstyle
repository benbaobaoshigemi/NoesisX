# Publication-quality matplotlib style adapted for this project
figure.dpi: 100
figure.facecolor: white
figure.autolayout: False
figure.constrained_layout.use: True
figure.figsize: 4.8, 3.2

font.size: 9
font.family: sans-serif
font.sans-serif: PingFang SC, Hiragino Sans GB, Source Han Sans SC, Noto Sans CJK SC, Arial, Helvetica, DejaVu Sans
axes.unicode_minus: False
svg.fonttype: none
pdf.fonttype: 42
ps.fonttype: 42

axes.linewidth: 0.8
axes.labelsize: 10
axes.titlesize: 11
axes.labelweight: normal
axes.spines.top: False
axes.spines.right: False
axes.edgecolor: black
axes.axisbelow: True
axes.grid: True
axes.prop_cycle: cycler('color', ['4C78A8', 'F58518', '54A24B', 'E45756', '72B7B2', 'B279A2', '9D755D', 'BAB0AC'])

grid.color: D1D5DB
grid.linestyle: --
grid.linewidth: 0.7

xtick.major.size: 3
xtick.minor.size: 2
xtick.major.width: 0.8
xtick.minor.width: 0.6
xtick.labelsize: 8
xtick.direction: in
ytick.major.size: 3
ytick.minor.size: 2
ytick.major.width: 0.8
ytick.minor.width: 0.6
ytick.labelsize: 8
ytick.direction: in

lines.linewidth: 2
lines.markersize: 5
lines.markeredgewidth: 0.6

legend.fontsize: 8
legend.frameon: False
legend.loc: best
legend.borderaxespad: 0.6

savefig.dpi: 300
savefig.format: png
savefig.bbox: tight
savefig.pad_inches: 0.08
savefig.transparent: False
savefig.facecolor: white

image.cmap: viridis
image.aspect: auto
